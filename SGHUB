local player = game:GetService("Players").LocalPlayer

local speedValue = 16 -- default walk speed
local enabled = false

local Input = Section:Input({
    Title = "Speed Value",
    Value = "16",
    Placeholder = "Enter number...",
    Callback = function(input)
        local num = tonumber(input)
        if num then
            speedValue = num
            print("Speed set to: " .. speedValue)

            -- apply instantly if toggle is ON
            if enabled and player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.WalkSpeed = speedValue
            end
        else
            warn("Invalid number")
        end
    end
})

local Toggle = Section:Toggle({
    Title = "Speed",
    Desc = "Enable / Disable Speed",
    Value = false,
    Callback = function(state)
        enabled = state

        local char = player.Character or player.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")

        if enabled then
            hum.WalkSpeed = speedValue
            print("Speed Enabled")
        else
            hum.WalkSpeed = 16 -- reset to normal
            print("Speed Disabled")
        end
