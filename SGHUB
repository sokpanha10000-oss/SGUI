local Library = loadstring(game:HttpGet("https://pastefy.app/1kFFcTWj/raw"))()

local Window = Library:CreateWindow({
    Title = "SK",
    Subtitle = "| By STEVEKHMER",
    Image = "rbxassetid://128185233852701"
})

local MainTab = Window:AddTab("Main")

local MainGroup = MainTab:AddLeftGroupbox("All Features")

MainGroup:AddToggle("Toggle", { 
    Title = "Auto Cheese", 
    Desc = "TP", 
    Value = false, 
    Callback = function(state)
        _G.CheeseFarm = state

        if state then
            task.spawn(function()
                while _G.CheeseFarm do
                    local player = game.Players.LocalPlayer
                    local char = player.Character or player.CharacterAdded:Wait()
                    local root = char:WaitForChild("HumanoidRootPart")

                    local folder = workspace:FindFirstChild("FindCheese")
                    if folder then
                        for _, model in ipairs(folder:GetChildren()) do
                            if model:IsA("Model") then
                                local cheese = model:FindFirstChild("Cheese")

                                if cheese and cheese:IsA("BasePart") then
                                    -- ⚡ TP
                                    root.CFrame = cheese.CFrame + Vector3.new(0, 2, 0)

                                    -- 🖱️ BETTER CLICK (distance-safe)
                                    local cd = cheese:FindFirstChildOfClass("ClickDetector")
                                    if cd then
                                        fireclickdetector(cd, 0)
                                    end

                                    task.wait(0.05)
                                end
                            end
                        end
                    end

                    task.wait()
                end
            end)
        end
    end
})

MainGroup:AddButton({ 
    Title = "Remove Rat", 
    Desc = "Deletes every model named Mouse", 

    Callback = function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == "Mouse" then
                obj:Destroy()
            end
        end
    end 
})

Library:Notify({
    Title = "Loaded",
    Description = "Everything is in one tab.",
    Duration = 3
})
