                tpConnection:Disconnect()
                tpConnection = nil
            end
        end
    end 
})

local Toggle = Section2:Toggle({
    Title = "Auto Get Mythical",
    Desc = "Auto farm + give super speed",
    Value = false,

    Callback = function(state)
        local player = game.Players.LocalPlayer
        local char = player.Character or player.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")

        if state then
            _G.AutoFarm = true

            -- RESET ON START (normal speed)
            hum.WalkSpeed = 16

            task.spawn(function()
                local reachedZone5 = false
                local collected = false

                while _G.AutoFarm do
                    char = player.Character
                    if not char or not char:FindFirstChild("HumanoidRootPart") then
                        task.wait()
                        continue
                    end

                    local hrp = char.HumanoidRootPart

                    -- 🥇 STEP 1: GO ZONE 5
                    if not reachedZone5 then
                        for _, v in ipairs(workspace:GetDescendants()) do
                            if v:IsA("BasePart") and v.Name == "5" then
                                hrp.CFrame = v.CFrame + Vector3.new(0, 3, 0)

                                for _, p in ipairs(v:GetDescendants()) do
                                    if p:IsA("ProximityPrompt") then
                                        fireproximityprompt(p)
                                        collected = true
                                    end
                                end

                                reachedZone5 = true
                                break
                            end
                        end
                    end

                    -- 🥈 STEP 2: FARM SpawnedItem
                    if reachedZone5 and not collected then
                        for _, v in ipairs(workspace:GetDescendants()) do
                            if v:IsA("Model") and v.Name == "SpawnedItem" then
                                local part = v:FindFirstChildWhichIsA("BasePart")
                                if part then
                                    hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)

                                    for _, p in ipairs(v:GetDescendants()) do
                                        if p:IsA("ProximityPrompt") then
                                            fireproximityprompt(p)
                                            collected = true
                                        end
                                    end
                                end
                            end
                        end
                    end

                    -- 🏁 AFTER COLLECT/FARM → STOP TP + SPEED BOOST
                    if collected then
                        _G.AutoFarm = false

                        -- stop TP instantly
                        task.wait(0.2)

                        -- 🚀 reward speed
                        hum.WalkSpeed = 360
                        break
                    end

                    task.wait()
                end
            end)

        else
