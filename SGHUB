local Toggle = Tab:Toggle({
    Title = "Tap TP Infinite",
    Desc = "Tap anywhere to teleport (no loop)",
    Icon = "door-open",
    Type = "Toggle",
    Value = false,

    Callback = function(state)
        local player = game.Players.LocalPlayer
        local mouse = player:GetMouse()

        -- store connection
        _G.TapTPConn = _G.TapTPConn or nil

        if state then
            -- prevent duplicate connections
            if _G.TapTPConn then return end

            _G.TapTPConn = mouse.Button1Down:Connect(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local hit = mouse.Hit
                    if hit then
                        char.HumanoidRootPart.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
                    end
                end
            end)

        else
            -- disconnect when toggle OFF
            if _G.TapTPConn then
                _G.TapTPConn:Disconnect()
                _G.TapTPConn = nil
            end
        end
    end
})

