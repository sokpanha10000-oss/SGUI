local Toggle = Section3:Toggle({
    Title = "Tap TP Infinite",
    Desc = "Tap anywhere to teleport (no loop)",
    Value = false,

    Callback = function(state)
        local player = game.Players.LocalPlayer
        local mouse = player:GetMouse()

        -- store connection
        _G.TapTPConn = _G.TapTPConn or nil

        if state then
            -- prevent duplicate connections
            if _G.TapTPConn then return end

            _G.TapTPConn = mouse.Button1Down:Connect(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local hit = mouse.Hit
                    if hit then
                        char.HumanoidRootPart.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
                    end
                end
            end)

        else
            -- disconnect when toggle OFF
            if _G.TapTPConn then
                _G.TapTPConn:Disconnect()
                _G.TapTPConn = nil
            end
        end
    end
})

local Toggle = Section4:Toggle({
    Title = "Auto Wins",
    Desc = "TP you to last area & auto wins",
    Value = false,

    Callback = function(state)
        _G.TP_Loop = state

        if state then
            task.spawn(function()
                while _G.TP_Loop do
                    local player = game.Players.LocalPlayer
                    local char = player.Character or player.CharacterAdded:Wait()
                    local hrp = char:FindFirstChild("HumanoidRootPart")

                    local stage = workspace:FindFirstChild("WinGivers")
                        and workspace.WinGivers:FindFirstChild("Stage 15")

                    if hrp and stage then
                        -- ✅ STEP 1: TP to Stage model (center)
                        if stage.PrimaryPart then
                            hrp.CFrame = stage.PrimaryPart.CFrame + Vector3.new(0, 5, 0)
                        else
                            hrp.CFrame = stage:GetPivot() + Vector3.new(0, 5, 0)
                        end

                        task.wait(0.3)

                        -- ✅ STEP 2: TP to Head
                        local head = stage:FindFirstChild("Head")
                        if head then
                            hrp.CFrame = head.CFrame + Vector3.new(0, 3, 0)
                            task.wait(0.3)
                        end

                        -- ✅ STEP 2: TP to Part
                        local part = stage:FindFirstChild("Part")
                        if part then
                            hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
                        end
                    end

                    task.wait(1)
                end
            end)
        end
    end
})

